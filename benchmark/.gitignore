# AOT-compiled scenario executables — produced by `python run.py build`.
# Reproducible from source; no need to track.
build/

# Local (uncommitted) run outputs. Checked-in baselines live in `results/`
# directly; this directory is for working copies during development.
results-local/

# Python virtualenv if a developer makes one here.
.venv/
venv/

# Python bytecode caches.
__pycache__/
*.pyc
